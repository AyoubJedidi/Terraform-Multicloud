# ============================================================
# TERRAFORM CONFIGURATION TEMPLATE
# ============================================================
# INSTRUCTIONS:
# 1. Copy this file: cp terraform.tfvars.example terraform.tfvars
# 2. Fill in your actual values
# 3. NEVER commit terraform.tfvars to Git!
# ============================================================

# Project Configuration
project_name         = "YOUR_PROJECT_NAME"        # e.g., "petclinic"
environment          = "dev"                      # dev, staging, or prod
cloud_provider       = "azure"                    # azure, aws, or gcp
deployment_type      = "webapp"                   # webapp or docker-vm

# Azure Configuration
azure_resource_group = "YOUR_RESOURCE_GROUP"      # e.g., "terraform-test-rg"
azure_location       = "francecentral"            # Azure region

# Container Registry Configuration
docker_image        = "YOUR_ACR.azurecr.io/YOUR_IMAGE:latest"
registry_server     = "YOUR_ACR.azurecr.io"
registry_username   = "YOUR_ACR_USERNAME"
registry_password   = "YOUR_ACR_PASSWORD"         # ⚠️ KEEP SECRET!

# GCP Configuration (required but can be dummy for Azure-only)
gcp_project = "dummy-project-id"

# ============================================================
# EXAMPLE VALUES:
# ============================================================
# project_name         = "petclinic"
# environment          = "dev"
# cloud_provider       = "azure"
# deployment_type      = "webapp"
# 
# azure_resource_group = "terraform-petclinic-rg"
# azure_location       = "francecentral"
# 
# docker_image        = "acrfrance4570.azurecr.io/petclinic:latest"
# registry_server     = "acrfrance4570.azurecr.io"
# registry_username   = "acrfrance4570"
# registry_password   = "9UlazxQwyuSeXj+7omSqKaZVlyLhEtM6Gi/uat+Kgm+ACRDSsSMU"
# 
# gcp_project = "dummy-project-id"
# ============================================================
